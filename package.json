{
  "name": "bridgeclaw-calendar-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "convex": "node ./node_modules/convex/bin/main.js",
    "convex:login": "node ./node_modules/convex/bin/main.js login",
    "convex:configure": "node ./node_modules/convex/bin/main.js dev --once --configure=new",
    "dev": "node scripts/dev.mjs",
    "serve:web": "node scripts/serve-web.mjs",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --test tests/**/*.test.mjs",
    "deploy:convex": "node ./node_modules/convex/bin/main.js deploy",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google/genai": "^0.14.1",
    "convex": "^1.25.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2"
  }
}
